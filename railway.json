{
  "build": {
    "cmd": "npm run build"
  },
  "deploy": {
    "startCommand": "npm start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "nixpacks": {
    "phases": {
      "install": {
        "cmds": ["npm install"]
      },
      "build": {
        "cmds": ["npm run build"]
      }
    },
    "start": "npm start"
  }
}
